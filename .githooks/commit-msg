#!/bin/sh
# Conventional Commits guard. Install with: ./gradlew installGitHooks
# (or: git config core.hooksPath .githooks)

commit_msg_file="$1"
first_line=$(head -n1 "$commit_msg_file")

# Allow merge/revert/fixup commits through untouched.
case "$first_line" in
  "Merge "*|"Revert "*|"fixup!"*|"squash!"*) exit 0 ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9\-]+\))?(!)?: .+'

if printf '%s' "$first_line" | grep -Eq "$pattern"; then
  exit 0
fi

echo "✗ Commit message does not follow Conventional Commits."
echo ""
echo "  Expected: <type>(<optional scope>): <subject>"
echo "  Types:    feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
echo ""
echo "  Example:  feat(pos): add split-payment flow"
echo "            fix(mdm): re-throw CancellationException in poll loop"
echo ""
echo "  Your message: $first_line"
exit 1
